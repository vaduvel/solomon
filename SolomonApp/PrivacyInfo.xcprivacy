<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Privacy Manifest pentru Solomon (App Store iOS 17+ required) -->

    <!-- Tracking: Solomon NU urmărește userii cross-app/cross-website -->
    <key>NSPrivacyTracking</key>
    <false/>

    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Data collected — toate sunt LOCAL pe device, NU trimise la server -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <!-- Profilul user (nume, vârstă interval, salariu interval) — local doar -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeName</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Tranzacții & financial data — local doar -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherFinancialInfo</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>

    <!-- API Reasons — required iOS 17+ pentru anumite API-uri sensitive -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- UserDefaults — folosit pentru onboarding flag, consent, settings -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>CA92.1</string><!-- App functionality — first-run flag, settings -->
            </array>
        </dict>

        <!-- File timestamp — folosit pentru cache MLX model + detection lastUsedDaysAgo -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>C617.1</string><!-- App functionality — cache management -->
            </array>
        </dict>

        <!-- System boot time — folosit indirect prin Date() arithmetic -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySystemBootTime</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>35F9.1</string><!-- Compute time intervals for Date math -->
            </array>
        </dict>

        <!-- Disk space — folosit pentru MLX model download verification -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>E174.1</string><!-- App functionality — model download check -->
            </array>
        </dict>
    </array>
</dict>
</plist>
